# Sync opcional entre dispositivos (§4.11) — APAGADO por defecto.
# La app es 100% local; solo poner "true" si se quiere ofrecer la opción avanzada.
NEXT_PUBLIC_ENABLE_CLOUD_SYNC=false

# Supabase — SOLO se usa si el sync opcional está activado
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Entorno: local | development | staging | production
APP_ENV=local
